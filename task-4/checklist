Here’s the correct and complete PyPy3 solution for your problem 👇

if __name__ == '__main__':
    n = int(input().strip())

    if n % 2 == 1:
        print("Weird")
    else:
        if 2 <= n <= 5:
            print("Not Weird")
        elif 6 <= n <= 20:
            print("Weird")
        else:
            print("Not Weird")
